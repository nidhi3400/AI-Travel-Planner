generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trip {
  id            String   @id @default(uuid())
  destination   String
  budget        Int
  duration      Int
  sourceCity    String
  interests     String[]
  estimatedCost Int
  itinerary     Json
  searchKey     String   @unique
  createdAt     DateTime @default(now())
}